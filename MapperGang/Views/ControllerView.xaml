<UserControl x:Class="MapperGang.Views.ControllerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:MapperGang.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:SymbolIcon Symbol="XboxConsole24" Foreground="#2076FF" Margin="0,0,8,0"/>
                    <TextBlock Text="Controller Settings" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
                <TextBlock Text="Configure virtual controller settings and behavior" 
                          Foreground="#AAAAAA" Margin="0,0,0,8"/>
            </StackPanel>
            <ui:Card Background="#222222">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Controller Type" Margin="0,8"/>
                        <ComboBox SelectedItem="{Binding SelectedControllerType}" Margin="0,0,0,16" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Xbox 360 Controller"/>
                            <ComboBoxItem Content="PlayStation Controller"/>
                        </ComboBox>

                        <TextBlock Text="Controller Number" Margin="0,8"/>
                        <ComboBox SelectedItem="{Binding ControllerNumber}" Margin="0,0,0,16" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Controller 1"/>
                            <ComboBoxItem Content="Controller 2"/>
                            <ComboBoxItem Content="Controller 3"/>
                            <ComboBoxItem Content="Controller 4"/>
                        </ComboBox>


                        <Grid Margin="0,8,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Vibration" VerticalAlignment="Center"/>
                                <TextBlock Text="Enable vibration feedback emulation" 
                                           FontSize="12" Foreground="#AAAAAA"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding VibrationEnabled}"/>
                        </Grid>


                        <Grid Margin="0,8,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Hide Physical Controllers" VerticalAlignment="Center"/>
                                <TextBlock Text="Hide physical controllers from games" 
                                           FontSize="12" Foreground="#AAAAAA"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding HidePhysicalControllers}"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Button Pressure Sensitivity" Grid.Column="0" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding ButtonPressureSensitivity, StringFormat={}{0:F0}%}" 
                                       Grid.Column="1" Foreground="#2076FF" Margin="0,0,0,8"/>
                        </Grid>
                        <TextBlock Text="Adjust pressure sensitivity for analog buttons" 
                                   FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,8"/>
                        <Slider Value="{Binding ButtonPressureSensitivity}" 
                                Maximum="100" Minimum="0" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Trigger Deadzone" Grid.Column="0" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TriggerDeadzone, StringFormat={}{0:F0}%}" 
                                       Grid.Column="1" Foreground="#2076FF" Margin="0,0,0,8"/>
                        </Grid>
                        <Slider Value="{Binding TriggerDeadzone}" 
                                Maximum="100" Minimum="0" Margin="0,0,0,16"/>


                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Vibration Strength" Grid.Column="0" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding VibrationStrength, StringFormat={}{0:F0}%}" 
                                       Grid.Column="1" Foreground="#2076FF" Margin="0,0,0,8"/>
                        </Grid>
                        <Slider Value="{Binding VibrationStrength}" 
                                Maximum="100" Minimum="0" Margin="0,0,0,16"
                                IsEnabled="{Binding VibrationEnabled}"/>

                        <TextBlock Text="Button Assignment Mode" Margin="0,8,0,8"/>
                        <StackPanel Orientation="Vertical" Margin="0,0,0,16">
                            <RadioButton Content="Standard" GroupName="ButtonMode" IsChecked="{Binding ButtonAssignmentMode, ConverterParameter=Standard, Mode=TwoWay}"/>
                            <RadioButton Content="Custom" GroupName="ButtonMode" IsChecked="{Binding ButtonAssignmentMode, ConverterParameter=Custom, Mode=TwoWay}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <ui:Card Background="#222222">
                <StackPanel>
                    <TextBlock Text="Advanced Controller Options" 
                               FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,16,0">

                            <Grid Margin="0,8,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Exclusive Mode" VerticalAlignment="Center"/>
                                    <TextBlock Text="Take exclusive control of the virtual controller" 
                                               FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ExclusiveMode}"/>
                            </Grid>

                            <Grid Margin="0,8,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Combine Inputs" VerticalAlignment="Center"/>
                                    <TextBlock Text="Combine multiple input sources for one output" 
                                               FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CombineInputs}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="16,0,0,0">

                            <Grid Margin="0,8,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Pass-through Mode" VerticalAlignment="Center"/>
                                    <TextBlock Text="Pass physical controller inputs to virtual controller" 
                                               FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding PassThroughMode}"/>
                            </Grid>

                            <Grid Margin="0,8,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Auto-Connect" VerticalAlignment="Center"/>
                                    <TextBlock Text="Automatically connect controller on startup" 
                                               FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoConnect}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0" 
                               Command="{Binding RestartDeviceCommand}"
                               Appearance="Secondary">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowReset24" Margin="0,0,8,0"/>
                                <TextBlock Text="Restart Device" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>

                        <ui:Button Grid.Column="2" 
                               Command="{Binding SaveSettingsCommand}"
                               Appearance="Primary">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Save24" Margin="0,0,8,0"/>
                                <TextBlock Text="Save Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <ui:Card Background="#222222">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ui:SymbolIcon Symbol="XboxConsole24" Foreground="#2076FF" Margin="0,0,8,0"/>
                        <TextBlock Text="Button Mapping" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Controller Button" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Grid.Column="1" Text="Current Assignment" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Grid.Column="2" Text="Actions" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBlock Grid.Column="0" Text="A Button" Margin="0,8"/>
                        <TextBlock Grid.Column="1" Text="Default (A)" Margin="0,8"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:Button Appearance="Transparent" Padding="4">
                                <ui:SymbolIcon Symbol="Settings24" Foreground="#BBBBBB"/>
                            </ui:Button>
                            <ui:Button Appearance="Transparent" Padding="4">
                                <ui:SymbolIcon Symbol="Delete24" Foreground="#F44336"/>
                            </ui:Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>