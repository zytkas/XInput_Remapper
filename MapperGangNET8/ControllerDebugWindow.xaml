<ui:FluentWindow x:Class="MapperGangNET8.Views.ControllerDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Controller Debug" Height="700" Width="950"
        Background="#171717">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Controller Debug" FontWeight="Bold" FontSize="18" Margin="0,0,0,10" Foreground="White"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <!-- Controls for connecting/disconnecting -->
                <ui:ToggleSwitch x:Name="ConnectToggle" Content="Connected" Margin="0,0,20,0" 
                                Checked="ConnectToggle_Checked" Unchecked="ConnectToggle_Unchecked"/>

                <ComboBox x:Name="ControllerTypeComboBox" Width="140" Margin="0,0,10,0" SelectedIndex="0">
                    <ComboBoxItem Content="Xbox 360"/>
                    <ComboBoxItem Content="DualShock 4"/>
                </ComboBox>

                <ComboBox x:Name="ControllerIndexComboBox" Width="100" Margin="0,0,20,0" SelectedIndex="0">
                    <ComboBoxItem Content="Controller 1"/>
                    <ComboBoxItem Content="Controller 2"/>
                    <ComboBoxItem Content="Controller 3"/>
                    <ComboBoxItem Content="Controller 4"/>
                </ComboBox>

                <ui:Button Content="Clear Log" Margin="0,0,0,0" Click="ClearLog_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: Log display -->
            <Border Grid.Column="0" BorderBrush="#333333" BorderThickness="1" Margin="0,10,10,10" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Controller Log" FontWeight="SemiBold" Margin="10,10,10,0" Foreground="White"/>

                    <TextBox x:Name="LogTextBox" Grid.Row="1" IsReadOnly="True" 
                         FontFamily="Consolas" FontSize="12"
                         Background="#1E1E1E" Foreground="White" BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Margin="10"/>
                </Grid>
            </Border>

            <!-- Right panel: Controller visualization -->
            <Border Grid.Column="1" BorderBrush="#333333" BorderThickness="1" Margin="10,10,0,10" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Controller Visualization" FontWeight="SemiBold" Margin="10,10,10,0" Foreground="White"/>

                    <!-- Controller Visualization -->
                    <Canvas Grid.Row="1" x:Name="ControllerCanvas" Margin="15" Height="220">
                        <!-- Controller body outline - Light gray stroke, transparent fill -->

                        <!-- Left trigger label -->
                        <TextBlock Canvas.Left="60" Canvas.Top="8" Text="LT" Foreground="#AAAAAA" FontSize="10"/>

                        <!-- Right trigger label -->
                        <TextBlock Canvas.Left="220" Canvas.Top="7" Text="RT" Foreground="#AAAAAA" FontSize="10"/>

                        <!-- Left bumper label -->
                        <TextBlock Canvas.Left="60" Canvas.Top="28" Text="LB" Foreground="#AAAAAA" FontSize="10"/>

                        <!-- Right bumper label -->
                        <TextBlock Canvas.Left="220" Canvas.Top="28" Text="RB" Foreground="#AAAAAA" FontSize="10"/>

                        <!-- Left trigger -->
                        <Path x:Name="LeftTrigger" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                              Canvas.Left="70" Canvas.Top="10"
                              Data="M 0,0 L 20,0 C 25,0 25,8 20,8 L 0,8 Z"/>

                        <!-- Right trigger -->
                        <Path x:Name="RightTrigger" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                              Canvas.Left="230" Canvas.Top="10"
                              Data="M 0,0 L 20,0 C 25,0 25,8 20,8 L 0,8 Z"/>

                        <!-- Left bumper -->
                        <Path x:Name="LeftShoulder" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                              Canvas.Left="70" Canvas.Top="30"
                              Data="M 0,0 L 20,0 C 25,0 25,8 20,8 L 0,8 Z"/>

                        <!-- Right bumper -->
                        <Path x:Name="RightShoulder" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                              Canvas.Left="230" Canvas.Top="30"
                              Data="M 0,0 L 20,0 C 25,0 25,8 20,8 L 0,8 Z"/>

                        <!-- Left thumbstick base -->
                        <Ellipse x:Name="LeftStickBase" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                                 Canvas.Left="60" Canvas.Top="43" Width="40" Height="40"/>

                        <!-- Left thumbstick -->
                        <Ellipse x:Name="LeftStick" Fill="#444444" Stroke="#777777" StrokeThickness="1"
                                 Canvas.Left="75" Canvas.Top="58" Width="10" Height="10"/>

                        <!-- Right thumbstick base -->
                        <Ellipse x:Name="RightStickBase" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                                 Canvas.Left="220" Canvas.Top="43" Width="40" Height="40" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <!-- Right thumbstick -->
                        <Ellipse x:Name="RightStick" Fill="#444444" Stroke="#777777" StrokeThickness="1"
                                 Canvas.Left="235" Canvas.Top="58" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <!-- Improved D-Pad with better visual representation -->
                        <Grid Canvas.Left="100" Canvas.Top="140" Width="30" Height="30">
                            <!-- D-pad background -->
                            <Ellipse Fill="#222222" Stroke="#444444" StrokeThickness="1" Width="30" Height="30" Margin="194,-109,-194,109"/>

                            <!-- D-pad directional buttons -->
                            <Grid Margin="194,-109,-194,109">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="10"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="10"/>
                                </Grid.ColumnDefinitions>

                                <!-- D-pad Up button -->
                                <Path x:Name="DPadUp" Fill="Transparent" Stroke="#777777" StrokeThickness="1" 
                                      Grid.Row="0" Grid.Column="1"
                                      Data="M 0,10 L 5,0 10,10 Z"/>

                                <!-- D-pad Left button -->
                                <Path x:Name="DPadLeft" Fill="Transparent" Stroke="#777777" StrokeThickness="1" 
                                      Grid.Row="1" Grid.Column="0"
                                      Data="M 10,0 L 0,5 10,10 Z"/>

                                <!-- D-pad Center -->
                                <Ellipse x:Name="DPadCenter" Fill="#333333" Stroke="#777777" StrokeThickness="0.5" 
                                        Grid.Row="1" Grid.Column="1" Width="6" Height="6" 
                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- D-pad Right button -->
                                <Path x:Name="DPadRight" Fill="Transparent" Stroke="#777777" StrokeThickness="1" 
                                      Grid.Row="1" Grid.Column="2"
                                      Data="M 0,0 L 10,5 0,10 Z"/>

                                <!-- D-pad Down button -->
                                <Path x:Name="DPadDown" Fill="Transparent" Stroke="#777777" StrokeThickness="1" 
                                      Grid.Row="2" Grid.Column="1"
                                      Data="M 0,0 L 5,10 10,0 Z"/>
                            </Grid>
                        </Grid>

                        <!-- Face buttons group -->
                        <Canvas Canvas.Left="200" Canvas.Top="70">
                            <!-- Button X -->
                            <Ellipse x:Name="ButtonX" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                                     Canvas.Left="-61" Canvas.Top="-22" Width="14" Height="15"/>
                            <TextBlock Canvas.Left="-57" Canvas.Top="-20" Text="X" Foreground="#AAAAAA" FontSize="10"/>

                            <!-- Button Y -->
                            <Ellipse x:Name="ButtonY" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                                     Canvas.Left="-33" Canvas.Top="-22" Width="15" Height="15"/>
                            <TextBlock Canvas.Left="-28" Canvas.Top="-20" Text="Y" Foreground="#AAAAAA" FontSize="10"/>

                            <!-- Button B -->
                            <Ellipse x:Name="ButtonB" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                                     Canvas.Left="-33" Canvas.Top="-2" Width="15" Height="14"/>
                            <TextBlock Canvas.Left="-28" Text="B" Foreground="#AAAAAA" FontSize="10"/>

                            <!-- Button A -->
                            <Ellipse x:Name="ButtonA" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                                     Canvas.Left="-61" Canvas.Top="-2" Width="15" Height="15"/>
                            <TextBlock Canvas.Left="-56" Text="A" Foreground="#AAAAAA" FontSize="10"/>
                        </Canvas>

                        <!-- Start and Back buttons -->
                        <Ellipse x:Name="ButtonBack" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                                 Canvas.Left="146" Canvas.Top="33" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <Ellipse x:Name="ButtonStart" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                                 Canvas.Left="161" Canvas.Top="33" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <!-- Guide button -->
                        <Ellipse x:Name="ButtonGuide" Fill="Transparent" Stroke="#777777" StrokeThickness="1"
                                 Canvas.Left="151" Canvas.Top="10" Width="20" Height="20"/>
                    </Canvas>

                    <!-- Testing controls -->
                    <StackPanel Grid.Row="1" Margin="10,86,10,10" Grid.RowSpan="2">
                        <TextBlock Text="Test Controls" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="White"/>

                        <TextBlock Text="Button Press Test" Margin="0,5,0,5" Foreground="#AAAAAA"/>
                        <WrapPanel Margin="0,0,0,10">
                            <ui:Button Content="A" Margin="2" Click="TestButton_Click" Tag="A"/>
                            <ui:Button Content="B" Margin="2" Click="TestButton_Click" Tag="B"/>
                            <ui:Button Content="X" Margin="2" Click="TestButton_Click" Tag="X"/>
                            <ui:Button Content="Y" Margin="2" Click="TestButton_Click" Tag="Y"/>
                            <ui:Button Content="LB" Margin="2" Click="TestButton_Click" Tag="LeftShoulder"/>
                            <ui:Button Content="RB" Margin="2" Click="TestButton_Click" Tag="RightShoulder"/>
                            <ui:Button Content="Start" Margin="2" Click="TestButton_Click" Tag="Start"/>
                            <ui:Button Content="Back" Margin="2" Click="TestButton_Click" Tag="Back"/>
                            <ui:Button Content="Guide" Margin="2" Click="TestButton_Click" Tag="Guide"/>
                        </WrapPanel>

                        <!-- D-Pad Controls -->
                        <TextBlock Text="D-Pad Test" Margin="0,5,0,5" Foreground="#AAAAAA"/>
                        <Grid Width="120" Height="90">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ui:Button Grid.Row="0" Grid.Column="1" Content="↑" Margin="1" 
                                       Click="TestButton_Click" Tag="DPadUp" FontSize="14"/>
                            <ui:Button Grid.Row="1" Grid.Column="0" Content="←" Margin="1" 
                                       Click="TestButton_Click" Tag="DPadLeft" FontSize="14"/>
                            <ui:Button Grid.Row="1" Grid.Column="2" Content="→" Margin="1" 
                                       Click="TestButton_Click" Tag="DPadRight" FontSize="14"/>
                            <ui:Button Grid.Row="2" Grid.Column="1" Content="↓" Margin="1" 
                                       Click="TestButton_Click" Tag="DPadDown" FontSize="14"/>
                        </Grid>

                        <Grid Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Left Trigger" Foreground="#AAAAAA"/>
                                <Slider x:Name="LeftTriggerSlider" Minimum="0" Maximum="1" Value="0" Margin="0,5,0,0"
                                       ValueChanged="TriggerSlider_ValueChanged" Tag="LeftTrigger"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Right Trigger" Foreground="#AAAAAA"/>
                                <Slider x:Name="RightTriggerSlider" Minimum="0" Maximum="1" Value="0" Margin="0,5,0,0"
                                       ValueChanged="TriggerSlider_ValueChanged" Tag="RightTrigger"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                            <ui:Button Content="Test in Windows" Margin="0,0,10,0" Click="OpenWindowsGameControllerTest_Click"/>
                            <ui:Button Content="Reset All" Click="ResetController_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Section -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Button state display -->
            <Border Grid.Column="0" BorderBrush="#333333" BorderThickness="1" Margin="0,0,5,0" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Button State" FontWeight="SemiBold" Margin="10,10,10,0" Foreground="White"/>
                    <TextBox x:Name="ButtonStateTextBox" Grid.Row="1" IsReadOnly="True" 
                             Background="#1E1E1E" Foreground="White" BorderThickness="0"
                             Height="80" Margin="10"/>
                </Grid>
            </Border>

            <!-- Axis state display -->
            <Border Grid.Column="1" BorderBrush="#333333" BorderThickness="1" Margin="5,0,0,0" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Axis State" FontWeight="SemiBold" Margin="10,10,10,0" Foreground="White"/>
                    <TextBox x:Name="AxisStateTextBox" Grid.Row="1" IsReadOnly="True" 
                             Background="#1E1E1E" Foreground="White" BorderThickness="0"
                             Height="80" Margin="10"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>