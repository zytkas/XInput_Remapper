<UserControl x:Class="MapperGangNET8.Views.Controls.CurveEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400"
             x:Name="CurveEditorControl">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Curve Graph -->
        <Border Grid.Row="0" 
                BorderBrush="#333333" 
                BorderThickness="1" 
                Background="#222222" 
                Margin="0,0,0,8">
            <Canvas x:Name="CurveCanvas" 
                    ClipToBounds="True"
                    MouseLeftButtonDown="CurveCanvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="CurveCanvas_MouseLeftButtonUp"
                    MouseMove="CurveCanvas_MouseMove">
                <!-- Grid lines will be drawn programmatically -->
                <!-- Curve will be drawn programmatically -->

                <!-- Control points will be drawn programmatically -->
            </Canvas>
        </Border>

        <!-- Controls for parameters -->
        <Grid Grid.Row="1" x:Name="ParametersPanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Exponential parameters -->
            <StackPanel x:Name="ExponentialPanel" Grid.Column="0" Margin="0,0,4,0" Visibility="Collapsed">
                <TextBlock Text="Exponent" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="ExponentSlider" 
                           Minimum="1" Maximum="5" Value="2"
                           ValueChanged="Parameter_ValueChanged"/>
                    <TextBlock Grid.Column="1" Text="{Binding ElementName=ExponentSlider, Path=Value, StringFormat={}{0:F1}}" 
                              Margin="8,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- S-Curve parameters -->
            <StackPanel x:Name="SCurvePanel" Grid.Column="0" Grid.ColumnSpan="2" Visibility="Collapsed">
                <TextBlock Text="Strength" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="StrengthSlider" 
                           Minimum="0" Maximum="1" Value="0.5"
                           ValueChanged="Parameter_ValueChanged"/>
                    <TextBlock Grid.Column="1" Text="{Binding ElementName=StrengthSlider, Path=Value, StringFormat={}{0:F2}}" 
                              Margin="8,0,0,0"/>
                </Grid>

                <TextBlock Text="Midpoint" Margin="0,8,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="MidpointSlider" 
                           Minimum="0.1" Maximum="0.9" Value="0.5"
                           ValueChanged="Parameter_ValueChanged"/>
                    <TextBlock Grid.Column="1" Text="{Binding ElementName=MidpointSlider, Path=Value, StringFormat={}{0:F2}}" 
                              Margin="8,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- Custom curve instructions -->
            <TextBlock x:Name="CustomCurveInstructions" 
                      Grid.Column="0" Grid.ColumnSpan="2"
                      Text="Click and drag to add and move control points"
                      Visibility="Collapsed"
                      HorizontalAlignment="Center"
                      Foreground="#AAAAAA"/>

            <!-- Reset button for custom curve -->
            <ui:Button x:Name="ResetCustomCurveButton"
                     Grid.Column="1"
                     Content="Reset to Linear"
                     Appearance="Secondary"
                     HorizontalAlignment="Right"
                     Visibility="Collapsed"
                     Click="ResetCustomCurve_Click"/>
        </Grid>
    </Grid>
</UserControl>