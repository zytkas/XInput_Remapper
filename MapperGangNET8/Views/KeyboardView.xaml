<UserControl x:Class="MapperGangNET8.Views.KeyboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:MapperGangNET8.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:SymbolIcon Symbol="Keyboard24" Foreground="#2076FF" Margin="0,0,8,0"/>
                    <TextBlock Text="Keyboard Settings" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
                <TextBlock Text="Configure how keyboard inputs are mapped to the virtual controller" 
                          Foreground="#AAAAAA" Margin="0,0,0,8"/>
            </StackPanel>

            <ui:Card Background="#222222">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Keyboard Layout" Margin="0,8"/>
                        <ComboBox ItemsSource="{Binding AvailableKeyboardLayouts}" 
                          SelectedItem="{Binding KeyboardLayout}" 
                          Margin="0,0,0,16" 
                          HorizontalAlignment="Stretch"/>

                        <Grid Margin="0,8,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Key Repeat" VerticalAlignment="Center"/>
                                <TextBlock Text="Enable key repeat for held keys" 
                                           FontSize="12" Foreground="#AAAAAA"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding KeyRepeatEnabled}"/>
                        </Grid>

                        <TextBlock Text="Key Repeat Rate" Margin="0,8,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Value="{Binding KeyRepeatRate}" Maximum="100" Minimum="0" Grid.Column="0"
                                    IsEnabled="{Binding KeyRepeatEnabled}"/>
                            <TextBlock Text="{Binding KeyRepeatRate, StringFormat={}{0:F0}%}" 
                                       Grid.Column="1" Foreground="#2076FF" Margin="8,0,0,0"/>
                        </Grid>

                        <TextBlock Text="Analog Key Sensitivity" Margin="0,16,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Value="{Binding AnalogKeySensitivity}" Maximum="100" Minimum="0" Grid.Column="0"/>
                            <TextBlock Text="{Binding AnalogKeySensitivity, StringFormat={}{0:F0}%}" 
                                       Grid.Column="1" Foreground="#2076FF" Margin="8,0,0,0"/>
                        </Grid>
                        <TextBlock Text="Adjust sensitivity for analog inputs (like triggers)" 
                                   FontSize="12" Foreground="#AAAAAA" Margin="0,4,0,16"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock Text="Movement Keys" FontWeight="SemiBold" Margin="0,8,0,16"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.Column="1" Background="#333333" Padding="16,8" Margin="2">
                                <TextBlock Text="{Binding MovementUp}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Background="#333333" Padding="16,8" Margin="2">
                                <TextBlock Text="{Binding MovementLeft}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Background="#333333" Padding="16,8" Margin="2">
                                <TextBlock Text="{Binding MovementDown}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" Background="#333333" Padding="16,8" Margin="2">
                                <TextBlock Text="{Binding MovementRight}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>

                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Maps to Left Stick" 
                                      HorizontalAlignment="Center" Foreground="#AAAAAA" Margin="0,4,0,0"/>
                        </Grid>

                        <TextBlock Text="Movement Style" Margin="0,16,0,8"/>
                        <StackPanel>
                            <RadioButton Content="8-Way (Diagonal)" GroupName="MovementStyle" 
                                         IsChecked="{Binding MovementStyle, ConverterParameter=8-Way, Mode=TwoWay}" Margin="0,4"/>
                            <RadioButton Content="4-Way (Cardinal)" GroupName="MovementStyle" 
                                         IsChecked="{Binding MovementStyle, ConverterParameter=4-Way, Mode=TwoWay}" Margin="0,4"/>
                        </StackPanel>

                        <Grid Margin="0,16,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Analog Keyboard" VerticalAlignment="Center"/>
                                <TextBlock Text="Enable analog emulation for digital keyboard inputs" 
                                           FontSize="12" Foreground="#AAAAAA"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding AnalogKeyboardEnabled}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <ui:Card Background="#222222">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Keyboard Button Mapping" FontSize="16" FontWeight="SemiBold" Grid.Column="0"/>
                        <ui:Button Grid.Column="1" Appearance="Secondary" Command="{Binding AddMappingCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Add24" Margin="0,0,4,0"/>
                                <TextBlock Text="Add Mapping"/>
                            </StackPanel>
                        </ui:Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Keyboard Key" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Controller Button" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Actions" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding ButtonMappings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox Grid.Column="0" 
                          ItemsSource="{Binding DataContext.AvailableKeyboardKeys, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                          SelectedItem="{Binding KeyboardKey}" 
                          Margin="0,0,8,0"/>

                                    <ComboBox Grid.Column="1" 
                          ItemsSource="{Binding DataContext.AvailableControllerActions, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                          SelectedItem="{Binding ControllerButton}" 
                          Margin="8,0"/>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <ui:Button Appearance="Transparent" Padding="4" ToolTip="Advanced Settings">
                                            <ui:SymbolIcon Symbol="Settings24" Foreground="#BBBBBB"/>
                                        </ui:Button>
                                        <ui:Button Appearance="Transparent" Padding="4" ToolTip="Remove Mapping"
                            Command="{Binding DataContext.RemoveMappingCommand, 
                                        RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                            CommandParameter="{Binding}">
                                            <ui:SymbolIcon Symbol="Delete24" Foreground="#F44336" />
                                        </ui:Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ui:Card>

            <Grid Margin="0,8,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0" 
                               Command="{Binding ResetToDefaultsCommand}"
                               Appearance="Secondary">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowReset24" Margin="0,0,8,0"/>
                        <TextBlock Text="Reset to default" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>

                <ui:Button Grid.Column="2" 
                               Command="{Binding SaveMappingsCommand}"
                               Appearance="Primary">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Save24" Margin="0,0,8,0"/>
                        <TextBlock Text="Save Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>