<UserControl x:Class="MapperGangNET8.Views.KeyboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:MapperGangNET8.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:SymbolIcon Symbol="Keyboard24" Foreground="#2076FF" Margin="0,0,8,0"/>
                    <TextBlock Text="Keyboard Settings" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
                <TextBlock Text="Configure keyboard inputs mapped to the virtual controller"
                          Foreground="#AAAAAA" Margin="0,0,0,8"/>
            </StackPanel>

            <!-- Movement Keys Card -->
            <ui:Card Background="#222222">
                <StackPanel>
                    <TextBlock Text="Movement Keys" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <Grid HorizontalAlignment="Center" Margin="0,8,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <!-- Up -->
                        <Border Grid.Row="0" Grid.Column="1" Background="#333333" Padding="20,12" Margin="4">
                            <TextBlock Text="{Binding MovementUp}" HorizontalAlignment="Center"
                                       FontWeight="SemiBold" FontSize="16" Foreground="White"/>
                        </Border>

                        <!-- Left, Down, Right -->
                        <Border Grid.Row="1" Grid.Column="0" Background="#333333" Padding="20,12" Margin="4">
                            <TextBlock Text="{Binding MovementLeft}" HorizontalAlignment="Center"
                                       FontWeight="SemiBold" FontSize="16" Foreground="White"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Background="#333333" Padding="20,12" Margin="4">
                            <TextBlock Text="{Binding MovementDown}" HorizontalAlignment="Center"
                                       FontWeight="SemiBold" FontSize="16" Foreground="White"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="2" Background="#333333" Padding="20,12" Margin="4">
                            <TextBlock Text="{Binding MovementRight}" HorizontalAlignment="Center"
                                       FontWeight="SemiBold" FontSize="16" Foreground="White"/>
                        </Border>

                        <!-- Description -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                   Text="→ Maps to Left Stick"
                                   HorizontalAlignment="Center"
                                   Foreground="#AAAAAA"
                                   Margin="0,8,0,0"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Button Mappings Card -->
            <ui:Card Background="#222222">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Button Mappings" FontSize="14" FontWeight="SemiBold" Grid.Column="0"/>
                        <ui:Button Grid.Column="1" Appearance="Secondary" Command="{Binding AddMappingCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Add24" Margin="0,0,4,0"/>
                                <TextBlock Text="Add Mapping"/>
                            </StackPanel>
                        </ui:Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Keyboard Key" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Controller Button" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Actions" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding ButtonMappings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding DataContext.AvailableKeyboardKeys, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                                              SelectedItem="{Binding KeyboardKey}"
                                              Margin="0,0,8,0"/>

                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding DataContext.AvailableControllerActions, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                                              SelectedItem="{Binding ControllerButton}"
                                              Margin="8,0"/>

                                    <ui:Button Grid.Column="2"
                                               Appearance="Transparent"
                                               Padding="4"
                                               ToolTip="Remove Mapping"
                                               HorizontalAlignment="Center"
                                               Command="{Binding DataContext.RemoveMappingCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                                               CommandParameter="{Binding}">
                                        <ui:SymbolIcon Symbol="Delete24" Foreground="#F44336" />
                                    </ui:Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ui:Card>

            <!-- Bottom action buttons -->
            <Grid Margin="0,8,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0"
                           Command="{Binding ResetToDefaultsCommand}"
                           Appearance="Secondary">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowReset24" Margin="0,0,8,0"/>
                        <TextBlock Text="Reset to default" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>

                <ui:Button Grid.Column="2"
                           Command="{Binding SaveMappingsCommand}"
                           Appearance="Primary">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Save24" Margin="0,0,8,0"/>
                        <TextBlock Text="Save Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
