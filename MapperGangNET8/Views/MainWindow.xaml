<ui:FluentWindow x:Class="MapperGang.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:MapperGang.Views"
        xmlns:viewmodels="clr-namespace:MapperGang.ViewModels"
        mc:Ignorable="d"
        Title="VirtualJoy" Height="650" Width="1000" 
        WindowStartupLocation="CenterScreen"
        Background="#171717"
        Foreground="White">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
           
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:Button x:Name="DashboardTab" Content="Dashboard" Tag="0" Click="NavigationButton_Click"
                      Appearance="Primary" Margin="0,0,4,0" 
                      FontWeight="SemiBold" Foreground="#2076FF"/>
                <ui:Button x:Name="ControllerTab" Content="Controller" Tag="1" Click="NavigationButton_Click"
                      Appearance="Secondary" Margin="4,0"/>
                <ui:Button x:Name="MouseTab" Content="Mouse" Tag="2" Click="NavigationButton_Click"
                      Appearance="Secondary" Margin="4,0"/>
                <ui:Button x:Name="KeyboardTab" Content="Keyboard" Tag="3" Click="NavigationButton_Click"
                      Appearance="Secondary" Margin="4,0"/>
                <ui:Button x:Name="SensitivityTab" Content="Sensitivity" Tag="4" Click="NavigationButton_Click"
                      Appearance="Secondary" Margin="4,0"/>
                <ui:Button x:Name="SettingsTab" Content="Settings" Tag="5" Click="NavigationButton_Click"
                      Appearance="Secondary" Margin="4,0"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="Profile:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Width="120" SelectedIndex="0" VerticalAlignment="Center">
                    <ComboBoxItem Content="Default"/>
                </ComboBox>

                <ui:Button Content="Stop" 
                          Background="#F44336" 
                          Foreground="White" 
                          Margin="16,0,0,0"/>
            </StackPanel>
        </Grid>
        <Grid x:Name="DashboardPanel" Grid.Row="1" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Панели статуса и быстрых настроек -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>

                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Панель статуса -->
                <ui:Card Grid.Column="0" Margin="0,0,8,0" Background="#222222">
                    <Grid VerticalAlignment="Stretch" Height="Auto">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Заголовок -->
                            <RowDefinition Height="240"/>
                            <!-- Основное содержимое, будет растягиваться -->
                            <RowDefinition Height="Auto"/>
                            <!-- Кнопка внизу -->
                        </Grid.RowDefinitions>

                        <!-- Заголовок -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="BatteryCharge20" Foreground="#4CAF50" Margin="0,0,8,0"/>
                            <TextBlock Text="Status" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>

                        <!-- Информация о статусе - использует все доступное пространство -->
                        <Grid Grid.Row="1" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <!-- Добавляем пустую растягивающуюся строку -->
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Device Status -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Device Status" Margin="0,8"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,8">
                                <Ellipse Width="10" Height="10" Fill="#4CAF50" Margin="0,0,6,0"/>
                                <TextBlock Text="Active" Foreground="#4CAF50"/>
                            </StackPanel>

                            <!-- Device Type -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Device Type" Margin="0,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Xbox 360 Controller" Margin="0,8"/>

                            <!-- Device ID -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Device ID" Margin="0,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="VID_045E&amp;PID_028E" Margin="0,8"/>

                            <!-- Active Profile -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Active Profile" Margin="0,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Default" Margin="0,8"/>
                        </Grid>

                        <!-- Кнопка перезапуска -->
                        <ui:Button Grid.Row="2" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Bottom"
                      Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="ArrowReset24" Margin="0,0,8,0"/>
                                <TextBlock Text="Restart Device" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                    </Grid>
                </ui:Card>

                <!-- Панель быстрых настроек -->
                <ui:Card Grid.Column="1" Margin="8,0,0,0" Background="#222222" >
                    <Grid VerticalAlignment="Stretch" Height="Auto">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Заголовок -->
                            <RowDefinition Height="*"/>
                            <!-- Содержимое -->
                        </Grid.RowDefinitions>

                        <!-- Заголовок -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="TopSpeed24" Foreground="#2076FF" Margin="0,0,8,0"/>
                            <TextBlock Text="Quick Settings" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>

                        <!-- Настройки - используют все доступное пространство -->
                        <Grid Grid.Row="1" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Mouse Sensitivity Label -->
                                <RowDefinition Height="Auto"/>
                                <!-- Mouse Sensitivity Slider -->
                                <RowDefinition Height="Auto"/>
                                <!-- Joystick Sensitivity Label -->
                                <RowDefinition Height="Auto"/>
                                <!-- Joystick Sensitivity Slider -->
                                <RowDefinition Height="Auto"/>
                                <!-- Response Curves Label -->
                                <RowDefinition Height="*"/>
                                <!-- Curves (растягивается) -->
                            </Grid.RowDefinitions>

                            <!-- Mouse Sensitivity -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Mouse Sensitivity" Grid.Column="0" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding MouseSensitivity, StringFormat={}{0:F0}%}" Grid.Column="1" Foreground="#2076FF" Margin="0,0,0,8"/>
                            </Grid>

                            <Slider Grid.Row="1" Value="{Binding MouseSensitivity}" Maximum="100" Minimum="0" Margin="0,0,0,16"/>

                            <!-- Joystick Sensitivity -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Joystick Sensitivity" Grid.Column="0" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding JoystickSensitivity, StringFormat={}{0:F0}%}" Grid.Column="1" Foreground="#2076FF" Margin="0,0,0,8"/>
                            </Grid>

                            <Slider Grid.Row="3" Value="{Binding JoystickSensitivity}" Maximum="100" Minimum="0" Margin="0,0,0,16"/>

                            <!-- Response Curves -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Response Curves" Grid.Column="0" Margin="0,0,0,8"/>
                                <ui:Button Content="Edit Curves" Grid.Column="1" 
                              Appearance="Secondary" 
                              Foreground="#2076FF"/>
                            </Grid>

                            <!-- Curves Display - растягивается на оставшееся место -->
                            <Grid Grid.Row="5" VerticalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Mouse" HorizontalAlignment="Center" Margin="0,8"/>
                                    <Border Height="100" Width="150" BorderBrush="#333333" BorderThickness="1" Margin="0,4" HorizontalAlignment="Center">
                                        <Line X1="0" Y1="100" X2="150" Y2="0" Stroke="#2076FF" StrokeThickness="2"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Joystick" HorizontalAlignment="Center" Margin="0,8"/>
                                    <Border Height="100" Width="150" BorderBrush="#333333" BorderThickness="1" Margin="0,4" HorizontalAlignment="Center">
                                        <Line X1="0" Y1="100" X2="150" Y2="0" Stroke="#2076FF" StrokeThickness="2"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </ui:Card>
            </Grid>
        </Grid>
        <ContentControl x:Name="ContentContainer" Grid.Row="1" Margin="0,16,0,0" 
                    Visibility="Collapsed" />
        <Border Grid.Row="3" Background="#1E1E1E" CornerRadius="8" Padding="16,12" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="MapperGang" FontWeight="SemiBold" Foreground="#BBBBBB"/>
                    <TextBlock Text=" v0.1.0 Beta" Foreground="#888888"/>
                    <Border Background="#333333" CornerRadius="4" Margin="12,0,0,0" Padding="6,2">
                        <TextBlock Text="Development Build" FontSize="11" Foreground="#AAAAAA"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Appearance="Transparent" Padding="8,4" ToolTip="GitHub">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Link24" Foreground="#888888" Margin="0,0,6,0"/>
                            <TextBlock Text="GitHub" Foreground="#888888" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>

                    <ui:Button Appearance="Transparent" Padding="8,4" Margin="4,0" ToolTip="Discord">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ChatMultiple24" Foreground="#888888" Margin="0,0,6,0"/>
                            <TextBlock Text="Discord" Foreground="#888888" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>

                    <Border Height="20" Width="1" Background="#333333" Margin="8,0"/>

                    <TextBlock Text="Made by zytka" Foreground="#888888" VerticalAlignment="Center" Margin="8,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>