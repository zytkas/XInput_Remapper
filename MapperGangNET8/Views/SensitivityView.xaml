<!-- MapperGang/Views/SensitivityView.xaml -->
<UserControl x:Class="MapperGang.Views.SensitivityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:MapperGang.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <!-- Заголовок и описание -->
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:SymbolIcon Symbol="TopSpeed24" Foreground="#2076FF" Margin="0,0,8,0"/>
                    <TextBlock Text="Sensitivity Settings" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
                <TextBlock Text="Configure mouse and joystick sensitivity and response curves" 
                          Foreground="#AAAAAA" Margin="0,0,0,8"/>
            </StackPanel>

            <!-- Основные настройки чувствительности -->
            <ui:Card Background="#222222">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая колонка - Настройки мыши -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <!-- Заголовок -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Mouse Sensitivity" FontWeight="SemiBold" Grid.Column="0"/>
                            <TextBlock Text="{Binding MouseSensitivityOverall, StringFormat={}{0:F0}%}" 
                                       Foreground="#2076FF" Grid.Column="1"/>
                        </Grid>

                        <!-- Ось X -->
                        <StackPanel Margin="0,16,0,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="X-Axis" Grid.Column="0"/>
                                <TextBlock Text="{Binding MouseXAxisSensitivity, StringFormat={}{0:F0}%}" 
                                           HorizontalAlignment="Right" Grid.Column="2"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="ArrowLeft24" Grid.Column="0" Margin="0,0,8,0"/>
                                <Slider Value="{Binding MouseXAxisSensitivity}" Minimum="0" Maximum="100" Grid.Column="1"/>
                                <ui:SymbolIcon Symbol="ArrowRight24" Grid.Column="2" Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- Ось Y -->
                        <StackPanel Margin="0,16,0,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Y-Axis" Grid.Column="0"/>
                                <TextBlock Text="{Binding MouseYAxisSensitivity, StringFormat={}{0:F0}%}" 
                                           HorizontalAlignment="Right" Grid.Column="2"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="ArrowLeft24" Grid.Column="0" Margin="0,0,8,0"/>
                                <Slider Value="{Binding MouseYAxisSensitivity}" Minimum="0" Maximum="100" Grid.Column="1"/>
                                <ui:SymbolIcon Symbol="ArrowRight24" Grid.Column="2" Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- Кривая отклика мыши -->
                        <Grid Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Response Curve" Grid.Column="0"/>
                            <ui:Button Content="Edit Curve" Grid.Column="1" 
                                       Appearance="Secondary" 
                                       Command="{Binding EditMouseCurveCommand}"
                                       Foreground="#2076FF"/>
                        </Grid>

                        <!-- График кривой отклика -->
                        <Border Height="120" BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,16">
                            <Path Data="M0,120 L300,0" Stroke="#2076FF" StrokeThickness="2"/>
                        </Border>

                        <!-- Пресеты кривой -->
                        <TextBlock Text="Curve Presets" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ui:Button Grid.Column="0" Content="Linear" 
                                       Command="{Binding SelectMouseCurvePresetCommand}" 
                                       CommandParameter="Linear"
                                       Appearance="{Binding MouseLinearCurveAppearance}"
                                       HorizontalAlignment="Stretch" Margin="0,0,4,0"/>

                            <ui:Button Grid.Column="1" Content="S-Curve" 
                                       Command="{Binding SelectMouseCurvePresetCommand}" 
                                       CommandParameter="S-Curve"
                                       Appearance="{Binding MouseSCurveAppearance}"
                                       HorizontalAlignment="Stretch" Margin="4,0"/>

                            <ui:Button Grid.Column="2" Content="Custom" 
                                       Command="{Binding SelectMouseCurvePresetCommand}" 
                                       CommandParameter="Custom"
                                       Appearance="{Binding MouseCustomCurveAppearance}"
                                       HorizontalAlignment="Stretch" Margin="4,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- Правая колонка - Настройки джойстика -->
                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <!-- Заголовок -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Joystick Settings" FontWeight="SemiBold" Grid.Column="0"/>
                            <TextBlock Text="{Binding JoystickSensitivity, StringFormat={}{0:F0}%}" 
                                       Foreground="#2076FF" Grid.Column="1"/>
                        </Grid>

                        <!-- Чувствительность джойстика -->
                        <StackPanel Margin="0,16,0,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sensitivity" Grid.Column="0"/>
                                <TextBlock Text="{Binding JoystickSensitivity, StringFormat={}{0:F0}%}" 
                                           HorizontalAlignment="Right" Grid.Column="2"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="ArrowLeft24" Grid.Column="0" Margin="0,0,8,0"/>
                                <Slider Value="{Binding JoystickSensitivity}" Minimum="0" Maximum="100" Grid.Column="1"/>
                                <ui:SymbolIcon Symbol="ArrowRight24" Grid.Column="2" Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- Мертвая зона джойстика -->
                        <StackPanel Margin="0,16,0,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Dead Zone" Grid.Column="0"/>
                                <TextBlock Text="{Binding JoystickDeadzone, StringFormat={}{0:F0}%}" 
                                           HorizontalAlignment="Right" Grid.Column="2"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="ArrowLeft24" Grid.Column="0" Margin="0,0,8,0"/>
                                <Slider Value="{Binding JoystickDeadzone}" Minimum="0" Maximum="100" Grid.Column="1"/>
                                <ui:SymbolIcon Symbol="ArrowRight24" Grid.Column="2" Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- Кривая отклика джойстика -->
                        <Grid Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Response Curve" Grid.Column="0"/>
                            <ui:Button Content="Edit Curve" Grid.Column="1" 
                                       Appearance="Secondary" 
                                       Command="{Binding EditJoystickCurveCommand}"
                                       Foreground="#2076FF"/>
                        </Grid>

                        <!-- График кривой отклика -->
                        <Border Height="120" BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,16">
                            <Path Data="M0,120 L300,0" Stroke="#2076FF" StrokeThickness="2"/>
                        </Border>

                        <!-- Пресеты кривой -->
                        <TextBlock Text="Curve Presets" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ui:Button Grid.Column="0" Content="Linear" 
                                       Command="{Binding SelectJoystickCurvePresetCommand}" 
                                       CommandParameter="Linear"
                                       Appearance="{Binding JoystickLinearCurveAppearance}"
                                       HorizontalAlignment="Stretch" Margin="0,0,4,0"/>

                            <ui:Button Grid.Column="1" Content="Step" 
                                       Command="{Binding SelectJoystickCurvePresetCommand}" 
                                       CommandParameter="Step"
                                       Appearance="{Binding JoystickStepCurveAppearance}"
                                       HorizontalAlignment="Stretch" Margin="4,0"/>

                            <ui:Button Grid.Column="2" Content="Custom" 
                                       Command="{Binding SelectJoystickCurvePresetCommand}" 
                                       CommandParameter="Custom"
                                       Appearance="{Binding JoystickCustomCurveAppearance}"
                                       HorizontalAlignment="Stretch" Margin="4,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Расширенные настройки чувствительности -->
            <ui:Card Background="#222222">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ui:SymbolIcon Symbol="Settings24" Foreground="#2076FF" Margin="0,0,8,0"/>
                        <TextBlock Text="Advanced Sensitivity Options" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая колонка - Расширенные настройки мыши -->
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Mouse Options" FontWeight="SemiBold" Margin="0,0,0,16"/>

                            <!-- Ускорение мыши -->
                            <Grid Margin="0,8,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Acceleration" VerticalAlignment="Center"/>
                                    <TextBlock Text="Enable mouse acceleration for dynamic response" 
                                               FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding MouseAcceleration}"/>
                            </Grid>

                            <!-- Сглаживание -->
                            <Grid Margin="0,8,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Smoothing" VerticalAlignment="Center"/>
                                    <TextBlock Text="Apply smoothing to mouse movements" 
                                               FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding MouseSmoothingEnabled}"/>
                            </Grid>

                            <!-- Блокировка осей -->
                            <Grid Margin="0,8,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Axis Lock" VerticalAlignment="Center"/>
                                    <TextBlock Text="Lock movement to a single axis at a time" 
                                               FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding MouseAxisLock}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Правая колонка - Расширенные настройки джойстика -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="Joystick Options" FontWeight="SemiBold" Margin="0,0,0,16"/>

                            <!-- Анти-мертвая зона -->
                            <Grid Margin="0,8,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Anti-Deadzone" VerticalAlignment="Center"/>
                                    <TextBlock Text="Compensate for controller deadzone" 
                                               FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding JoystickAntiDeadzone}"/>
                            </Grid>

                            <!-- Поворот джойстика -->
                            <Grid Margin="0,8,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Rotation" VerticalAlignment="Center"/>
                                    <TextBlock Text="Rotate joystick input direction" 
                                               FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding JoystickRotation}"/>
                            </Grid>

                            <!-- Радиальная мертвая зона -->
                            <Grid Margin="0,8,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Radial Deadzone" VerticalAlignment="Center"/>
                                    <TextBlock Text="Use radial instead of per-axis deadzone" 
                                               FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding JoystickRadialDeadzone}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <Grid Margin="0,8,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0" 
                               Command="{Binding ResetToDefaultsCommand}"
                               Appearance="Secondary">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowReset24" Margin="0,0,8,0"/>
                        <TextBlock Text="Reset to default" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>

                <ui:Button Grid.Column="2" 
                               Command="{Binding SaveMappingsCommand}"
                               Appearance="Primary">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Save24" Margin="0,0,8,0"/>
                        <TextBlock Text="Save Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>